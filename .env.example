# Provider selection: hf | groq | openai
LLM_PROVIDER=groq

# Shared model setting
MODEL_NAME=llama-3.3-70b-versatile

# Optional explicit base URL override
API_BASE_URL=https://api.groq.com/openai/v1

# Hugging Face Router key (for LLM_PROVIDER=hf)
HF_TOKEN=

# Groq key (for LLM_PROVIDER=groq)
# ---> PASTE YOUR GROQ API KEY HERE <---
GROQ_API_KEY=your_groq_api_key
# OpenAI key (for LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Generic fallback key alias
API_KEY=